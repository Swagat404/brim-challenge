ANTHROPIC_API_KEY=sk-ant-...
# Production: comma-separated frontend origins (required for browser fetch from another host)
# CORS_ORIGINS=https://your-frontend.up.railway.app
DB_PATH=../brim_expenses.db
POLICY_PDF_PATH=../Brim Expense Policy.pdf
# Model to use for the expense agent
CLAUDE_MODEL=claude-sonnet-4-6
# Max agent loop steps before giving up
AGENT_MAX_STEPS=10
# Policy scan batch size (transactions per Claude call)
POLICY_BATCH_SIZE=15
