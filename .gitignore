*.mov

# Tooling (Claude, Cursor, Specstory)
.claude/
.cursor/
.specstory/

# Workspace file
*.code-workspace

# Unused module
policy-enforcer/
*.png
# but always ship product assets shipped with the frontend (logo, docs screenshots, etc.)
!frontend/public/**/*.png
!frontend/public/**/*.mp4
# and ship seeded demo receipts so the deployed app has working thumbnails
!backend/uploads/**/*.png
!backend/uploads/**/*.jpg
!backend/uploads/**/*.jpeg
