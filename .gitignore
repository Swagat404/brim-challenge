node_modules/
.pnp/
.pnp.js

# Build output
.next/
out/
dist/
build/

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
*.egg
.pytest_cache/
venv/
.venv/

# Environment variables
.env
.env.local
.env.*.local

# Database
*.db
*.sqlite
